# ─────────────────────────────────────────────────────────────
# Resume Maker — Frontend environment variables (.env.local)
# ─────────────────────────────────────────────────────────────

# NextAuth (Auth.js v5)
# Base URL of this app. In production set to https://resume-maker.takagi.bz
NEXTAUTH_URL=http://localhost:3000
# Random 32+ char secret. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars

# Google OAuth 2.0 credentials (from Google Cloud Console)
# Authorized redirect URI: <NEXTAUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Backend API base URL (FastAPI). Exposed to the browser.
NEXT_PUBLIC_API_URL=http://localhost:8000
